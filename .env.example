# Backend Database Configuration
DATABASE_URL=postgresql+psycopg2://user:password@localhost/f1db

# Authentication & Security
SECRET_KEY=your-secret-key-change-this-to-a-long-random-value
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=your-secure-password-here

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend Configuration (optional - used for Vite build)
# If not set, the frontend will auto-detect the API URL based on the current domain
VITE_API_URL=http://127.0.0.1:8000
